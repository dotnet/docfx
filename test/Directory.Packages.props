    <PackageVersion Include="Verify.XunitV3" Version="28.6.0" />
    <PackageVersion Include="xunit.runner.visualstudio" Version="3.0.1" />
    <PackageVersion Include="xunit.v3" Version="1.0.1" />
  </ItemGroup>

</Project>
